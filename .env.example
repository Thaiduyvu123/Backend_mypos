# ============================================
# Backend Environment Variables
# Copy file này thành .env và điền giá trị
# ============================================

# Server
PORT=3001

# MongoDB - Trong Docker dùng tên service "mongo"
MONGODB_URI=mongodb://mongo:27017/mypos

# JWT
JWT_SECRET=mypos_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_LOGIN_CALLBACK_URL=http://localhost/api/auth/google/login/callback
GOOGLE_REGISTER_CALLBACK_URL=http://localhost/api/auth/google/register/callback

# Gmail SMTP
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin seed (tài khoản admin mặc định khi chạy lần đầu)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456

# Session (cho Google OAuth)
SESSION_SECRET=your_session_secret_change_this
