# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/my1pos

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_LOGIN_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/login/callback
GOOGLE_REGISTER_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/register/callback

# Gmail SMTP
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456

# Session (cho Google OAuth)
SESSION_SECRET=your_session_secret
